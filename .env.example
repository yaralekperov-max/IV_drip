# ─────────────────────────────────────────────────────────────────────────────
# VENA — пример переменных окружения.
# Скопируй в .env.local и заполни. Секреты НЕ коммитим (.env* в .gitignore).
# ВАЖНО (152-ФЗ): вся инфраструктура — российский контур Яндекс Облака.
# ─────────────────────────────────────────────────────────────────────────────

# --- База данных: Managed Service for PostgreSQL (Яндекс Облако) ---
# Требует TLS. CA-сертификат Яндекса: https://storage.yandexcloud.net/cloud-certs/CA.pem
# Положи в корень как .yandex-ca.pem (уже игнорируется) и укажи путь ниже.
DATABASE_URL="postgres://user:password@rc1a-xxxx.mdb.yandexcloud.net:6432/vena?sslmode=verify-full"
DATABASE_CA_CERT_PATH=".yandex-ca.pem"

# --- Object Storage (S3-совместимое, Яндекс Облако) — хранение PDF анализов ---
S3_ENDPOINT="https://storage.yandexcloud.net"
S3_REGION="ru-central1"
S3_BUCKET="vena-medical"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# --- Авторизация: вход по коду из SMS (российский провайдер) ---
# Секрет для подписи сессионной cookie (HMAC). Задай длинную случайную строку.
AUTH_SESSION_SECRET=""
# Провайдер SMS. Пусто/не задано → dev-режим (код печатается в консоль сервера, реальная SMS не шлётся).
# Поддерживаемые (по мере реализации): "sms.ru"
SMS_PROVIDER=""
SMS_PROVIDER_API_KEY=""

# --- Платежи: ЮKassa (Этап 6) ---
# YOOKASSA_SHOP_ID=""
# YOOKASSA_SECRET_KEY=""

# --- CRM: amoCRM (Этап 6) ---
# AMOCRM_BASE_URL=""
# AMOCRM_ACCESS_TOKEN=""

# --- Приложение ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
